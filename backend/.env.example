# 大模型（OpenAI 兼容）。AI_API_KEY 留空时使用离线演示数据，便于本地评审。
# 切勿将真实密钥提交到版本库。
AI_API_KEY=

# 必须为「含 /v1 的根路径」，例如：
#   https://api.openai.com/v1
#   https://api.deepseek.com/v1
AI_BASE_URL=https://api.openai.com/v1

AI_MODEL=gpt-4o-mini

# 从 PDF 提取的文本最大长度（字符），防止单次请求过长
MAX_RESUME_TEXT_LENGTH=15000

# 上传 PDF 单文件大小上限（MB）
MAX_UPLOAD_FILE_MB=10
